# Apache .htaccess — place this at your IONOS webroot (htdocs/)

# ── Block sensitive files and directories from direct HTTP access ──────────
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

<FilesMatch "^config\.php$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
RewriteEngine On

# Block direct access to backend directories
RewriteRule ^(core|blogs|templates)/.*$ - [F,L]

# /blog/<blogword>[/anything] -> index.php?blog=<blogword>
RewriteRule ^blog/([A-Za-z0-9_-]+)(/.*)?$ index.php?blog=$1 [L,QSA]

# Root -> index.php (landing/onboarding)
RewriteRule ^$ index.php [L,QSA]
</IfModule>
